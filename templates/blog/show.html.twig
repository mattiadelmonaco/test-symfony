{% extends "base.html.twig" %}

{% block title %}{{ post.title }} - SymBlog{% endblock %}

{% block body %}

<h1> {{ post.title }} </h1>
<p>{{ post.createdAt|date('d/m/Y') }}</p>
<p>Autore: {{ post.author.username }}</p>
<p>{{ post.content }}</p>
<a href="{{ path('app_home') }}">Torna alla home</a>

{% endblock %}